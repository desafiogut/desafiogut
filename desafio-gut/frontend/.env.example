# ============================================================================
# .env.example — Netlify Functions (backend) · assinatura da coordenação
# ----------------------------------------------------------------------------
# Variáveis VITE_* do frontend (VITE_PRIVY_APP_ID, VITE_CONTRATO_SEPOLIA, …)
# vivem em .env.local / .env.production (NÃO commitados). Este ficheiro
# documenta apenas a configuração de assinatura on-chain (MC30.1).
# NUNCA committar valores reais — apenas placeholders.
# ============================================================================

# ── Seleção de rede e backend de assinatura (MC30.1) ────────────────────────
# NETWORK_STAGE: 'mainnet' ativa o caminho endurecido (Biconomy Smart Account +
# owner KMS). Qualquer outro valor (ou ausente) = testnet/localhost (chave de
# baixo valor).
NETWORK_STAGE=sepolia

# SIGNER_BACKEND: força o backend de assinatura, ignorando a heurística de
# NETWORK_STAGE. Valores: 'biconomy' | 'local-key'. Deixe vazio para auto
# (mainnet → biconomy, restante → local-key).
# MC31: o backend 'defender' (OpenZeppelin Defender Relay) foi REMOVIDO. O ALVO
# de produção é 'biconomy' (ERC-4337 + owner KMS) e é o default em mainnet.
SIGNER_BACKEND=

# ── RPC / contrato ──────────────────────────────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_CHAVE_AQUI
CONSOLIDATION_RPC_URL=https://rpc.flashbots.net/fast
# MC39.2 — fallback OPT-IN: se o Flashbots/RPC primário não responder, usa este.
# Vazio = sem fallback (usa só o primário, sem probe). Ex.: outro relay privado/RPC.
CONSOLIDATION_RPC_URL_FALLBACK=
CONTRATO_SEPOLIA=0x0000000000000000000000000000000000000000
CONTRATO_MAINNET=0x0000000000000000000000000000000000000000
MAINNET_CHAIN_ID=1

# ── Backend 'biconomy' — Biconomy ERC-4337 + owner KMS [MAINNET, MC30.2.1] ──
# ALVO de produção. O Smart Account (ERC-4337) executa as transações da
# coordenação; o Bundler resolve nativamente a concorrência de nonces (lances
# simultâneos) e o Paymaster subsidia o gás. O OWNER do Smart Account é uma
# chave em KMS/HSM remoto: a chave privada NUNCA entra neste ambiente (R9/R12).
# ⚠️ O endereço da coordenação passa a ser o do Smart Account (≠ EOA) — exige a
#    transferência two-step no contrato (iniciar/aceitarTransferenciaCoordenacao).
BICONOMY_API_KEY=
BICONOMY_BUNDLER_URL=https://bundler.biconomy.io/api/v3/CHAIN_ID/SUA_CHAVE
# MC39.2 — fallback OPT-IN do bundler: se o primário não responder (eth_chainId),
# usa este (ex.: Alchemy/Pimlico, mesmo EntryPoint). Vazio = sem fallback (sem probe).
BICONOMY_BUNDLER_URL_FALLBACK=
BICONOMY_PAYMASTER_URL=https://paymaster.biconomy.io/api/v2/CHAIN_ID/SUA_CHAVE
# KMS do OWNER (provider agnóstico). KMS_PROVIDER ∈ { aws | turnkey | fireblocks }.
# Apenas 'aws' está implementado nesta fase (recomendado). NUNCA a chave privada:
# só o identificador da chave + credenciais IAM ESCOPADAS e REVOGÁVEIS.
KMS_PROVIDER=aws
KMS_KEY_ID=arn:aws:kms:REGIAO:CONTA:key/SUA_KEY_ID
# ⚠️ Prefixo APP_AWS_* (NÃO AWS_*): no runtime Netlify Functions o prefixo AWS_ é
# reservado — o Lambda injeta as suas próprias AWS_* (papel de execução, SEM KMS).
# O código lê APP_AWS_* explicitamente (fallback para AWS_* fora do Netlify).
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY_ID=
APP_AWS_SECRET_ACCESS_KEY=
# Token DESCARTÁVEL do endpoint de diagnóstico mc302-diagnostico (gera com
# `openssl rand -hex 32`). Enviar no header x-mc302-diag-token. REMOVER após a
# migração — se ausente, o endpoint recusa (503) e nunca fica aberto.
MC302_DIAG_TOKEN=

# ── Backend 'local-key' — SOMENTE testnet/localhost (R3 / ITEM 3.9) ─────────
# Chave privada de uma carteira de TESTNET de BAIXO VALOR, usada só para correr
# IA auto / consolidação / crédito em Sepolia sem depender do KMS/Bundler.
# ⚠️ NÃO definir em mainnet nem com SIGNER_BACKEND=biconomy: a guarda recusa
#    arrancar se houver chave bruta em mainnet/biconomy (R9/R12, ITEM 4.1).
#    Em produção esta variável deve ser REMOVIDA do ambiente (Netlify), não só
#    deixada vazia — a assinatura ocorre no KMS, fora do processo.
COORDENACAO_PRIVATE_KEY=

# ── Camada de dados Supabase (MC32.1) ───────────────────────────────────────
# DATA_STORE_BACKEND seleciona a implementação da fachada _lib/data-store.mjs:
#   'blobs'    (default) → Netlify Blobs (atual).
#   'supabase'           → Supabase PostgreSQL (novo).
# Anti-Split-Brain (R11): a ESCRITA é exclusiva do backend ativo. NUNCA escrever
# nos dois ao mesmo tempo; o fallback só é permitido para LEITURA de histórico.
DATA_STORE_BACKEND=blobs

# Credenciais Supabase — SÓ env vars, NUNCA hardcoded (R9).
# SUPABASE_URL: endpoint do projeto (ex.: https://SEU_REF.supabase.co).
SUPABASE_URL=https://SEU_REF.supabase.co
# SERVICE_ROLE_KEY: chave de servidor (ignora RLS) — EXCLUSIVA do backend.
# NUNCA expor ao cliente nem committar o valor real.
SUPABASE_SERVICE_ROLE_KEY=
# ANON_KEY: chave pública de leitura (sujeita a RLS) — usada pelo FRONTEND para
# ler config_remota/produtos e subscrever o canal realtime. Vai em VITE_* no
# frontend (.env.local), aqui documentada para referência.
SUPABASE_ANON_KEY=

# Frontend (VITE_*) — lidas por src/lib/supabaseClient.js (import.meta.env).
# Sem ambas, o frontend mantém a leitura via função recursos-app (zero regressão).
# VITE_SUPABASE_URL = mesmo endpoint de SUPABASE_URL; VITE_SUPABASE_ANON_KEY = ANON_KEY.
VITE_SUPABASE_URL=https://SEU_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
